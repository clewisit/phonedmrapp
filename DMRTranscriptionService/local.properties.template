## This file was *NOT* generated by Android Studio
## Copy this file to 'local.properties' and fill in your values
## local.properties is in .gitignore and will NOT be committed to GitHub

# Android SDK path (automatically set by Android Studio)
sdk.dir=/path/to/your/android/sdk

# Google Cloud Speech-to-Text API Key
# Get your API key from: https://console.cloud.google.com/apis/credentials
# 1. Create a project (or use existing)
# 2. Enable "Cloud Speech-to-Text API"
# 3. Create API key in "Credentials"
# Cost: 60 minutes/month FREE, then $0.006 per 15 seconds (~$1.44/hour)
GOOGLE_CLOUD_API_KEY=YOUR_API_KEY_HERE
